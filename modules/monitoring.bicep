param location string = 'East US'\n\n// Azure Monitor\nresource monitor 'Microsoft.Insights/monitors@2021-06-01' = {\n  name: 'charis-monitor'\n  location: location\n  tags: {\n    project: 'Team Charis'\n    author: 'Aishat Oshileye'\n  }\n}\n\n// Log Analytics Workspace\nresource logAnalytics 'Microsoft.OperationalInsights/workspaces@2020-10-20' = {\n  name: 'charis-loganalytics'\n  location: location\n  sku: 'PerGB2018'\n  retentionInDays: 30\n}\n\n// Application Insights\nresource appInsights 'Microsoft.Insights/components@2020-02-02' = {\n  name: 'charis-appinsights'\n  location: location\n  kind: 'web'\n  applicationType: 'Web'\n}\n\n// Action Group\nresource actionGroup 'Microsoft.Insights/actionGroups@2021-08-01' = {\n  name: 'charis-actiongroup'\n  location: location\n  properties: {\n    groupShortName: 'CharisAlerts'\n    webhookReceivers: [{\n      name: 'Webhook'\n      serviceUri: 'https://example.com/webhook'\n    }]\n  }\n}\n\n// CPU alert rule\nresource cpuAlertRule 'Microsoft.Insights/metricAlerts@2021-03-01' = {\n  name: 'cpu-alert-rule'\n  location: location\n  properties: {\n    description: 'Alert when CPU usage exceeds 80%'\n    severity: 3\n    criteria: {\n      allOf: [{\n        metricName: 'Percentage CPU'\n        metricNamespace: 'Microsoft.Compute/virtualMachines'\n        operator: 'GreaterThan'\n        threshold: 80\n        aggregation: 'Average'\n      }]\n    }\n    action: {\n      actionGroupId: actionGroup.id\n    }\n  }\n}\n\n// Memory alert rule\nresource memoryAlertRule 'Microsoft.Insights/metricAlerts@2021-03-01' = {\n  name: 'memory-alert-rule'\n  location: location\n  properties: {\n    description: 'Alert when Memory usage exceeds 80%'\n    severity: 3\n    criteria: {\n      allOf: [{\n        metricName: 'Available Memory Bytes'\n        metricNamespace: 'Microsoft.Compute/virtualMachines'\n        operator: 'LessThan'\n        threshold: 80 * 1024 * 1024 * 1024\n        aggregation: 'Average'\n      }]\n    }\n    action: {\n      actionGroupId: actionGroup.id\n    }\n  }\n}\n\n// Diagnostic settings\nresource diagnostics 'Microsoft.Insights/diagnosticSettings@2021-05-01' = {\n  name: 'charis-diagnostics'\n  scope: appInsights.id\n  properties: {\n    workspaceId: logAnalytics.id\n    logs: [{\n      category: 'Request'\n      enabled: true\n    }]\n    metrics: [{\n      category: 'AllMetrics'\n      enabled: true\n    }]\n  }\n}